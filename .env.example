# Database (Docker PostgreSQL for ERP)
DATABASE_URL=postgresql+asyncpg://campusorbit:campusorbit@localhost:5432/campusorbit_erp

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=CampusOrbit ERP
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3001

# Institute
INSTITUTE_NAME=Your Institute Name
INSTITUTE_CODE=INST

# Razorpay
RAZORPAY_PAYMENT_BUTTON_ID=
